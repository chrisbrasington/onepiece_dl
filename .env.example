# Copy to .env and fill in real values. .env is gitignored — never commit it.

# --- Discord bot ---
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=
# Channel the bot auto-posts new chapters to (right-click channel -> Copy ID).
# Leave blank to disable auto-posting.
DISCORD_CHANNEL_ID=
# YouTube Data API key (for the /napier command)
YOUTUBE_API_KEY=

# --- Downloader (optional; sensible defaults exist) ---
# First chapter to try on a fresh volume (when last_chapter.txt is empty)
START_CHAPTER=

# --- Calibre-Web uploader ---
# Calibre-Web runs on the host, not in this stack. host.docker.internal points
# at the host from inside the container (compose maps it via host-gateway).
# If that fails, use the host's LAN IP instead, e.g. http://192.168.1.x:8083
CALIBRE_URL=http://host.docker.internal:8083
CALIBRE_USERNAME=
CALIBRE_PASSWORD=
